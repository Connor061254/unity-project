{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "b4e5b6db8d4b47ed89e8eb0446232677",
    "m_Title": "Hacky Depth",
    "m_Content": "Depth refracton with just nodes is tricky, you either see a ghosted version of the object underwater + refracted version layered on top, or you have good refraction that also unfortunately refracts above the surface too. \n\nThis is my attempt at fixing these problems.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -1848.6666259765625,
        "y": 544.0,
        "width": 200.0,
        "height": 181.3333740234375
    },
    "m_Group": {
        "m_Id": ""
    }
}

